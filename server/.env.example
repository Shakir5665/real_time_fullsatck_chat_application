# Backend Environment Variables Template
# Copy this file to .env and fill in the values.

# Database Configuration
# MongoDB connection URI (e.g., mongodb+srv://username:password@cluster.mongodb.net/dbname)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<database_name>

# JWT Authentication
# Random secret string for signing JSON Web Tokens
JWT_SECRET=your_jwt_secret_key_here

# Cloudinary Credentials (used for media uploads like images/attachments)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Server Configuration
PORT=5000
NODE_ENV=development

# Client URL (CORS Configuration - allow requests from this frontend URL)
CLIENT_URL=http://localhost:5173
