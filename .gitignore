# ==============================================================================
# PROFESSIONAL GITIGNORE FOR REAL-TIME FULL-STACK CHAT APPLICATION
# ==============================================================================

# ------------------------------------------------------------------------------
# Dependencies & Package Managers
# ------------------------------------------------------------------------------
# Ignore all node_modules directories recursively
node_modules/
jspm_packages/
web_modules/
.pnpm-store/

# Do NOT ignore package lockfiles (crucial for reproducible builds)
!package-lock.json
!yarn.lock
!pnpm-lock.yaml

# ------------------------------------------------------------------------------
# Environment Variables & Secrets
# ------------------------------------------------------------------------------
# Never commit credentials or local overrides to git
.env
.env.local
.env.development.local
.env.test.local
.env.production
.env.production.local
*.env
*.env.local

# ------------------------------------------------------------------------------
# Build and Compilation Outputs
# ------------------------------------------------------------------------------
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.serverless/
bin/
obj/

# ------------------------------------------------------------------------------
# Logs and Diagnostics
# ------------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------------------------
# IDE, Editors, and OS-Specific Files
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.lnk
*.cab

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/code-workspace

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/

# Editor backup/temporary files
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*~
*.bak
*.tmp
*.temp

# ------------------------------------------------------------------------------
# Testing and Coverage
# ------------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
.jest/

# ------------------------------------------------------------------------------
# Miscellaneous & Cache
# ------------------------------------------------------------------------------
.cache/
.eslintcache
.stylelintcache
.parcel-cache/
.turbo/
.vercel/
